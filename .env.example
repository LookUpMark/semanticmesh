# ── Sensitive Configuration (API Keys, Passwords) ───────────────────────────────
# Only sensitive values should be in .env — non-sensitive defaults are in:
#   src/config/config.py
#
# You can override any config.py value here by setting the corresponding
# environment variable (e.g., LLM_MODEL_REASONING=your_model).

# ── Neo4j ──────────────────────────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_password_here

# ── LLM (OpenRouter) ───────────────────────────────────────────────────────────
OPENROUTER_API_KEY=your_openrouter_api_key_here

# ── Optional: Override config.py defaults ───────────────────────────────────────
# Uncomment and modify any of these to override the defaults in src/config/config.py
#
# # LLM Models
# LLM_MODEL_REASONING=qwen/qwen3-coder:free
# LLM_MODEL_EXTRACTION=qwen/qwen3-next-80b-a3b-instruct:free
# LLM_TEMPERATURE_EXTRACTION=0.0
# LLM_TEMPERATURE_REASONING=0.0
# LLM_TEMPERATURE_GENERATION=0.3
#
# # Embeddings & Reranking
# EMBEDDING_MODEL=BAAI/bge-m3
# RERANKER_MODEL=BAAI/bge-reranker-large
# RERANKER_TOP_K=5
#
# # Entity Resolution
# ER_BLOCKING_TOP_K=10
# ER_SIMILARITY_THRESHOLD=0.85
#
# # Confidence & Loop Guards
# CONFIDENCE_THRESHOLD=0.90
# MAX_REFLECTION_ATTEMPTS=3
# MAX_CYPHER_HEALING_ATTEMPTS=3
# MAX_HALLUCINATION_RETRIES=3
# MAX_LLM_RETRIES=3
#
# # Chunking
# CHUNK_SIZE=512
# CHUNK_OVERLAP=64
#
# # Retrieval
# RETRIEVAL_VECTOR_TOP_K=20
# RETRIEVAL_BM25_TOP_K=10
# RETRIEVAL_GRAPH_DEPTH=2
#
# # Few-Shot
# FEW_SHOT_CYPHER_EXAMPLES=5
#
# # Ablation Flags
# ENABLE_SCHEMA_ENRICHMENT=true
# RETRIEVAL_MODE=hybrid
# ENABLE_CYPHER_HEALING=true
# ENABLE_CRITIC_VALIDATION=true
# ENABLE_RERANKER=true
# ENABLE_HALLUCINATION_GRADER=true
#
# # Logging
# LOG_LEVEL=INFO
